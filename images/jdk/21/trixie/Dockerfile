      org.opencontainers.image.licenses="${KEELINE_IMAGE_LICENSES}" \
      org.opencontainers.image.version="21.0.10"

ENTRYPOINT ["/usr/local/bin/keeline-java-entrypoint"]
CMD ["jshell"]
